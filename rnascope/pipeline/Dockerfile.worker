# Pipeline worker image — runs on AWS Batch
# Contains: Salmon, fastp, Python with pyDESeq2 + gseapy + scikit-learn

FROM condaforge/mambaforge:latest AS base

# Install bioinformatics tools via conda
RUN mamba install -y -c bioconda -c conda-forge \
    salmon=1.10.2 \
    fastp=0.23.4 \
    samtools=1.19 \
    && mamba clean -afy

# Install Python dependencies
RUN pip install --no-cache-dir \
    pydeseq2>=0.4 \
    gseapy>=1.1 \
    scikit-learn>=1.4 \
    pandas>=2.1 \
    numpy>=1.26 \
    scipy>=1.12 \
    anndata>=0.10 \
    boto3>=1.34 \
    anthropic>=0.18 \
    pybiomart>=0.2

WORKDIR /app

# Copy pipeline code
COPY rnascope/pipeline/worker.py /app/worker.py
COPY rnascope/pipeline/result_builder.py /app/result_builder.py

ENTRYPOINT ["python", "/app/worker.py"]
